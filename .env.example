# 网易云音乐 API 地址
# 可使用公共实例，或自行部署 NeteaseCloudMusicApi
# 部署教程：https://github.com/Binaryify/NeteaseCloudMusicApi
VITE_NETEASE_API_BASE=https://netease-cloud-music-api-demo.vercel.app

# 咪咕音乐 API 地址（可选）
# VITE_MIGU_API_BASE=https://your-migu-api.example.com

# B站音频 API 地址（可选）
# VITE_BILIBILI_API_BASE=https://your-bilibili-api.example.com

# AI 大模型配置
VITE_LLM_API_KEY=your_api_key_here
VITE_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
VITE_LLM_MODEL=glm-4

# AI 助手人设配置
VITE_AI_NAME=花语小精灵
VITE_AI_PERSONA=你是花语音乐的AI助手，叫花语小精灵。性格温柔治愈，说话有文艺感，像森林里的精灵一样。你懂音乐，也懂用户的心情，总能推荐到合适的歌。
